{
  "name": "eurogopass-admin-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "ingest:mail": "tsx mail-ingest.ts",
    "editorial:worker": "tsx editorial-worker.ts",
    "test": "node --import tsx --test editorial-api.test.ts",
    "ingest:mail:backfill": "tsx mail-ingest.ts --once --all",
    "gmail:authorize": "tsx scripts/gmail-authorize.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/dm-sans": "5.3.0",
    "@vitejs/plugin-react": "6.0.3",
    "connect": "3.7.0",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "lucide-react": "1.24.0",
    "mailparser": "3.9.14",
    "pdf-parse": "^2.4.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sirv": "3.0.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/connect": "3.4.38",
    "@types/mailparser": "3.4.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript-eslint": "8.63.0"
  }
}

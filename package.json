{
  "name": "eurogopass-admin-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "ingest:mail": "tsx mail-ingest.ts",
    "editorial:worker": "tsx editorial-worker.ts",
    "ingest:mail:backfill": "tsx mail-ingest.ts --once --all",
    "gmail:authorize": "tsx scripts/gmail-authorize.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "connect": "latest",
    "cross-env": "latest",
    "dotenv": "latest",
    "lucide-react": "latest",
    "mailparser": "latest",
    "pdf-parse": "^2.4.5",
    "react": "latest",
    "react-dom": "latest",
    "sirv": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/connect": "latest",
    "@types/mailparser": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "typescript-eslint": "latest"
  }

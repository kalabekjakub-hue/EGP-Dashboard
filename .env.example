# Demo data remain active until the live connectors are configured.
VITE_DATA_MODE=demo

# Supabase (public browser-safe values only; never put service_role here)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dashboard server (server-only; never expose these values to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EGP_ADMIN_EMAILS=info@eurogopass.com,kalabek.jakub@gmail.com,adamskrivanek007@gmail.com
EGP_PUBLIC_ORIGIN=https://admin.eurogopass.com
EGP_AUTH_FILE=/app/auth-data/users.json
HOST=127.0.0.1
PORT=3100

# Server-only Worker monitor connection. Never prefix the token with VITE_.
EGP_WORKER_MONITOR_URL=http://127.0.0.1:3090
EGP_WORKER_MONITOR_TOKEN=
EGP_WORKER_ENV_PATH=/opt/EGP-Worker/.env
WISE_WORKER_HEALTH_URL=http://127.0.0.1:3081/health

# Gmail official-document ingestion (OAuth with gmail.readonly scope)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_ID=me
GMAIL_ENV_PATH=secrets/gmail.env
MAIL_INGEST_INTERVAL_MS=60000
MAIL_INGEST_LOOKBACK_DAYS=30
# Complete historical import: npm run ingest:mail:backfill
MAIL_SENDER_COUNTRY_MAP_FILE=config/mail-senders.json
# JSON object: sender domain or exact address -> ISO country code.
# Start with observed official senders only, e.g. {"no-reply@portal.example":"CZ"}
MAIL_SENDER_COUNTRY_MAP={}

# Optional modules
VITE_POSTHOG_HOST=https://eu.posthog.com/project/215239/home
VITE_POSTHOG_KEY=

# PostHog server-only analytics API (never prefix the personal key with VITE_)
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# AI editorial (server/worker only; never prefix with VITE_)
OPENAI_API_KEY=
OPENAI_ARTICLE_MODEL=gpt-5.6-terra
OPENAI_TRANSLATION_MODEL=gpt-5.6-terra
OPENAI_UTILITY_MODEL=gpt-5.6-luna
EDITORIAL_POLL_INTERVAL_MS=300000

# Demo data remain active until the live connectors are configured.
VITE_DATA_MODE=demo

# Supabase (public browser-safe values only; never put service_role here)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Worker monitor connection. Never prefix the token with VITE_.
EGP_WORKER_MONITOR_URL=http://127.0.0.1:3090
EGP_WORKER_MONITOR_TOKEN=

# Optional modules
VITE_POSTHOG_HOST=https://eu.posthog.com/project/215239/home
VITE_POSTHOG_KEY=

# PostHog server-only analytics API (never prefix the personal key with VITE_)
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
